# API keys and secrets
.env
.env~

# deepseek-cli settings
# We want to keep the .deepseek in the root of the repo and ignore any .deepseek
# in subdirectories. In our root .deepseek we want to allow for version control
# for subcommands.
**/.deepseek/
!/.deepseek/
.deepseek/*
!.deepseek/config.yaml
!.deepseek/commands/
!.deepseek/skills/
!.deepseek/settings.json

# Note: .deepseek-clipboard/ is NOT in gitignore so DeepSeek can access pasted images

# Dependency directory
node_modules
bower_components

# Editors
.idea
*.iml

# OS metadata
.DS_Store
Thumbs.db

# TypeScript build info files
*.tsbuildinfo

# Ignore built ts files
dist

# Docker folder to help skip auth refreshes
.docker

bundle

# Test report files
junit.xml
packages/*/coverage/

# Generated files
packages/cli/src/generated/
packages/core/src/generated/
packages/devtools/src/_client-assets.ts
.integration-tests/
.perf-tests/
packages/vscode-ide-companion/*.vsix
packages/cli/download-ripgrep*/

# GHA credentials
gha-creds-*.json

# Log files
patch_output.log
deepseek-debug.log

.genkit
.deepseek-clipboard/
.eslintcache
evals/logs/

temp_agents/

# conductor extension and planning directories
conductor/
